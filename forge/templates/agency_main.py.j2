def build_agency() -> tuple[Agency, EventLog]:
    """Build and configure the {{ agency_name }} agency."""

    # ─── Observability ────────────────────────────────────
    cost_tracker = CostTracker()
    event_log = EventLog(cost_tracker=cost_tracker)

    # ─── Persistent Memory ────────────────────────────────
    os.makedirs("./data", exist_ok=True)
    memory = SharedMemory.persistent(db_path="./data/agency_memory.db")

    # ─── Quality & Performance ────────────────────────────
    performance_tracker = PerformanceTracker()
    feedback_collector = FeedbackCollector()
    quality_gate = QualityGate(min_score=0.8)

    # ─── Human Approval (optional) ───────────────────────────
    approval_gate = HumanApprovalGate(auto_approve_urgency=Urgency.LOW) if HumanApprovalGate else None

    # ─── Guardrails (optional) ─────────────────────────────
    guardrails = None
    if GuardrailsEngine:
        guardrails = GuardrailsEngine(
            content_filter=ContentFilter(block_pii=os.getenv("FORGE_BLOCK_PII", "true").lower() == "true"),
            action_limiter=ActionLimiter(
                max_tool_calls=int(os.getenv("FORGE_MAX_TOOL_CALLS", "50")),
                max_tokens=int(os.getenv("FORGE_MAX_TOKENS_PER_TASK", "100000")),
            ),
            scope_guard=ScopeGuard(),
        )

    # ─── Smart Model Routing (optional) ──────────────────
    model_router = None
    if ModelRouter:
        model_router = ModelRouter(
            default_model=os.getenv("FORGE_MODEL", "{{ model }}"),
            fast_model=os.getenv("FORGE_FAST_MODEL", "gpt-4o-mini"),
            enabled=os.getenv("FORGE_SMART_ROUTING", "false").lower() == "true",
        )

    # ─── Wire archetype tools to real infrastructure ───────
    if set_shared_infrastructure:
        set_shared_infrastructure(
            perf_tracker=performance_tracker,
            cost_tracker=cost_tracker,
            event_log=event_log,
        )

    # ─── Build Agency ─────────────────────────────────────
    agency = Agency(
        name="{{ agency_name }}",
        description="{{ description }}",
        model=os.getenv("FORGE_MODEL", "{{ model }}"),
        api_key=os.getenv("OPENAI_API_KEY"),
        base_url=os.getenv("OPENAI_BASE_URL"),
    )
    agency.memory = memory

    # ─── Domain Knowledge & Primitives ─────────────────────
    domain_knowledge = None
    if _has_primitives:
        domain_knowledge = get_domain_knowledge("{{ domain | default('') }}")
        if domain_knowledge and domain_knowledge.policies:
            memory.store("domain:knowledge", domain_knowledge.to_dict(), author="system", tags=["knowledge"])
            logger.info(f"Loaded domain knowledge: {len(domain_knowledge.policies)} policies")

    # ─── Checkpointing (optional) ────────────────────────────
    if CheckpointStore:
        agency.enable_checkpointing(db_path="./data/checkpoints.db")

    {% for team in teams %}
    # --- Team: {{ team.name }} ---
    {% if team.lead %}
    {{ team.name | pyname }}_lead = Agent(
        name="{{ team.lead.name }}",
        role="{{ team.lead.role }}",
        system_prompt="""{{ team.lead.system_prompt }}""",
        model="{{ team.lead.model }}",
        temperature={{ team.lead.temperature }},
        domain_knowledge=domain_knowledge if _has_primitives else None,
    )
    {% endif %}

    {{ team.name | pyname }}_agents = [
        {% for agent in team.agents %}
        Agent(
            name="{{ agent.name }}",
            role="{{ agent.role }}",
            system_prompt="""{{ agent.system_prompt }}""",
            model="{{ agent.model }}",
            temperature={{ agent.temperature }},
            domain_knowledge=domain_knowledge if _has_primitives else None,
            {% if agent.tools %}
            tools=[t for t in [{% for t in agent.tools %}_builtin_tools.get("{{ t.name }}"), {% endfor %}] if t is not None],
            {% endif %}
        ),
        {% endfor %}
    ]

    {{ team.name | pyname }}_team = Team(
        name="{{ team.name }}",
        {% if team.lead %}
        lead={{ team.name | pyname }}_lead,
        {% endif %}
        agents={{ team.name | pyname }}_agents,
    )
    agency.add_team({{ team.name | pyname }}_team)
    {% endfor %}

    # ─── Wire observability, quality gates, and approval ──
    for team in agency.teams.values():
        all_agents = list(team.agents)
        if team.lead:
            all_agents.append(team.lead)
        for agent in all_agents:
            agent.enable_reflection = True
            agent.set_quality_gate(quality_gate)
            agent.set_performance_tracker(performance_tracker)
            agent.set_event_log(event_log)
            if guardrails:
                agent.set_guardrails(guardrails)
            if model_router:
                agent.set_model_router(model_router)
            # Scoped tool access: leads/orchestrators get all tools; regular agents
            # keep only their blueprint-assigned tools plus a small universal set.
            _UNIVERSAL_TOOLS = {"web_search", "http_request"}
            if agent is team.lead:
                for prim_tool in _builtin_tools.values():
                    if prim_tool and prim_tool.name not in [t.name for t in agent.tool_registry.list_tools()]:
                        agent.tool_registry.register(prim_tool)
            else:
                for tool_name in _UNIVERSAL_TOOLS:
                    _utool = _builtin_tools.get(tool_name)
                    if _utool and _utool.name not in [t.name for t in agent.tool_registry.list_tools()]:
                        agent.tool_registry.register(_utool)
            # Apply domain-aware critic based on available knowledge
            if _has_primitives and domain_knowledge:
                if domain_knowledge.compliance_rules:
                    agent._critic = ComplianceCritic(rules=domain_knowledge.compliance_rules)
                elif domain_knowledge.quality_criteria:
                    agent._critic = ScoredCritic(min_score=0.7)
                else:
                    agent._critic = BinaryCritic()

    # ─── Initialize planner───────────────────────────────
    agency.planner.set_llm_client(agency._llm_client)
    agency.planner.set_teams(agency.teams)

    # ─── Build Loop (for code-generating agents) ──────────
    build_loop = BuildLoop(max_attempts=5) if BuildLoop else None
    if build_loop:
        agency._build_loop = build_loop

    # Attach advanced features to agency for API access
    agency._model_router = model_router

    # ─── Level 3-5: Autonomous Operation ───────────────────
    if _has_autonomous:
        agency.inbound.poll_interval = 30.0
        agency.self_evolution.set_infrastructure(
            tracker=performance_tracker,
            llm_client=agency._llm_client,
        )
        agency.agent_spawner.set_infrastructure(
            tracker=performance_tracker,
            llm_client=agency._llm_client,
        )
        logger.info("Level 3-5 autonomous systems initialized")

    # ═══════════════════════════════════════════════════════════
    # Seed initial data so APIs aren't empty on Day 1
    # ═══════════════════════════════════════════════════════════
    memory.store("company:name", "{{ agency_name }}", author="system", tags=["config"])

    # Seed policies from domain knowledge (if available) rather than hardcoding
    if domain_knowledge and domain_knowledge.policies:
        for idx, policy in enumerate(domain_knowledge.policies):
            memory.store(f"policy:{domain_knowledge.domain}:{idx}", policy, author="system", tags=["policy"])
        logger.info(f"Seeded {len(domain_knowledge.policies)} policies from domain knowledge")
    else:
        logger.info("No domain-specific policies to seed")

    logger.info("Seeded initial configuration")

    return agency, event_log


async def main():
    """Run the agency."""
    agency, event_log = build_agency()
    logger.info(f"Agency '{agency.name}' initialized: {agency}")
    
    print(f"\n🏢 {agency.name} is ready!")
    print(f"   {agency.description}")
    print(f"   Teams: {list(agency.teams.keys())}")
    print(f"   💾 Memory: Persistent (SQLite)")
    print(f"   📡 Observability: Event logging + cost tracking")
    print(f"   📐 Planner: Enabled")
    print(f"   ✅ Quality gates: Active (threshold 80%)")
    print(f"\n   Type a task, 'build: <task>' to build a project (recommended), or 'quit' to exit.")
    print(f"   Also: 'project: <task>' (legacy), 'plan: <task>' for planning.")
    print(f"   Type 'stress: <domain>' to run stress test with infinite improvement.")
    print(f"   Type 'autonomous' for 24/7 mode, 'evolve' for self-improvement, 'spawn' to detect gaps.\n")

    while True:
        try:
            task = input("📋 Task> ")
        except (EOFError, KeyboardInterrupt):
            break
        if task.lower() in ("quit", "exit", "q"):
            break
        if not task.strip():
            continue

        if task.lower().startswith("stress:"):
            domain = task[7:].strip() or "{{ domain | default('general') }}"
            print(f"🧪 Starting Stress Lab for '{domain}'...")
            reports = await agency.stress_lab.run_full_cycle(
                domain=domain,
                scenarios_per_round=10,
                target_pass_rate=0.90,
                max_cycles=3,
            )
            if reports:
                print(f"\n📊 Stress Lab Results:")
                for r in reports:
                    print(f"  Cycle {r.cycle}: {r.pass_rate:.0%} pass rate, {r.evolutions_applied} evolutions, {r.agents_spawned} spawns")
                print(f"\n  Improvement: {reports[0].pass_rate:.0%} → {reports[-1].pass_rate:.0%}")
            continue

        if task.lower() == "autonomous":
            print("🤖 Starting autonomous mode (24/7 operation)...")
            print("   Watching: API queue + ./inbox/ for file drops")
            print("   Press Ctrl+C to stop")
            await agency.inbound.start()
            try:
                while True:
                    await asyncio.sleep(60)
            except KeyboardInterrupt:
                await agency.inbound.stop()
                print("Autonomous mode stopped.")
            continue

        if task.lower() == "evolve":
            print("🧬 Running evolution cycle...")
            agent_map = {}
            for team in agency.teams.values():
                if team.lead:
                    agent_map[team.lead.name] = team.lead
                for a in team.agents:
                    agent_map[a.name] = a
            records = await agency.self_evolution.run_evolution_cycle(agent_map)
            print(f"   {len(records)} improvements applied")
            for r in records:
                print(f"   🧬 {r.target_agent}: {r.description[:60]}")
            continue

        if task.lower() == "spawn":
            print("🥚 Checking for agent gaps...")
            spawned = await agency.agent_spawner.check_and_spawn(agency)
            if spawned:
                for s in spawned:
                    print(f"   🆕 Spawned: {s.name} ({s.role}) — {s.reason}")
            else:
                print("   No gaps detected. All good!")
            continue

        if task.lower() == "status":
            print(f"\n📊 {agency.get_status()}")
            print(f"💰 Costs: {event_log.cost_tracker.get_summary()}")
            print(f"📝 Events: {event_log.get_summary()}")
            if hasattr(agency, '_model_router') and agency._model_router:
                print(f"🔀 Model routing: {agency._model_router.get_stats()}")
            continue

        if task.lower() == "memory":
            recent = agency.memory.search_keyword("", limit=10)
            for entry in recent:
                print(f"  💾 [{entry.get('key')}]: {str(entry.get('value'))[:80]}")
            continue

        # Create trace for this request
        trace = TraceContext()
        for team in agency.teams.values():
            all_agents = list(team.agents)
            if team.lead:
                all_agents.append(team.lead)
            for agent in all_agents:
                agent.set_trace_context(trace)

        # Build mode: single intelligent orchestrator loop (recommended)
        if task.lower().startswith("build:"):
            build_task = task[6:].strip()
            print("🏗️  Orchestrator building project (single intelligent loop)...")
            print("   This uses one agent with all tools — the correct architecture.")
            print("")
            result = await agency.orchestrate(build_task)
            print(f"\n{'='*50}")
            print(f"📦 {'COMPLETE' if result['success'] else 'PARTIAL'}")
            print(f"   Iterations: {result['iterations']}")
            print(f"   Files: {len(result['files_created'])}")
            print(f"   Duration: {result['duration_seconds']:.0f}s")
            if result['files_created']:
                print(f"\n   Files created:")
                for f in result['files_created']:
                    print(f"     📄 {f}")
            print(f"{'='*50}\n")
            continue

        # Project mode: multi-file, multi-agent project execution (legacy)
        if task.lower().startswith("project:"):
            project_task = task[8:].strip()
            print("🏗️  Building project (multi-file, multi-agent)...")
            print("   This may take several minutes...")
            project_result = await agency.execute_project(project_task)
            print(f"\n{'='*50}")
            print(f"📦 Project {'COMPLETE' if project_result['success'] else 'PARTIAL'}")
            print(f"   Steps: {project_result['steps_completed']}/{project_result['steps_total']}")
            print(f"   Files: {len(project_result['files_created'])}")
            print(f"   Duration: {project_result['duration_seconds']:.0f}s")
            print(f"   Cost: ${project_result['cost_usd']:.4f}")
            print(f"\n   Files created:")
            for f in project_result['files_created']:
                print(f"     📄 {f}")
            print(f"{'='*50}\n")
            continue

        # Use planner for complex tasks
        if task.lower().startswith("plan:") or task.count('.') > 1 or len(task) > 200:
            actual_task = task[5:].strip() if task.lower().startswith("plan:") else task
            print("📐 Planning and executing...")
            result = await agency.execute(actual_task, use_planner=True)
        else:
            result = await agency.execute(task)

        print(f"\n✅ Result (success={result.success}):\n{result.output}\n")


        trace_events = event_log.get_trace(trace.trace_id)
        if trace_events:
            print(f"📊 Trace: {len(trace_events)} events | 💰 Cost: ${event_log.cost_tracker.total_cost_usd:.4f}")

    # Print final summary on exit
    print(f"\n{'='*50}")
    print(f"📊 Session Summary")
    summary = event_log.get_summary()
    print(f"   Total events: {summary['total_events']}")
    print(f"   LLM calls: {summary['event_types'].get('llm_response', 0)}")
    print(f"   Tool uses: {summary['event_types'].get('tool_result', 0)}")
    costs = summary['costs']
    print(f"   Total tokens: {costs['total_tokens']:,}")
    print(f"   Total cost: ${costs['total_cost_usd']:.4f}")
    print(f"   Per agent: {json.dumps(costs['per_agent'], indent=2) if costs['per_agent'] else 'N/A'}")


if __name__ == "__main__":
    asyncio.run(main())
